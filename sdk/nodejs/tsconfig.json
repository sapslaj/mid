{
  "compilerOptions": {
    // Output
    "outDir": "bin",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "stripInternal": true,
    // Environment
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "types": ["node"],
    // Type Checking
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": true
  },
  "files": [
    "agent/agentPing.ts",
    "agent/ansibleExecute.ts",
    "agent/exec.ts",
    "agent/fileStat.ts",
    "agent/index.ts",
    "config/index.ts",
    "config/vars.ts",
    "index.ts",
    "provider.ts",
    "resource/ansibleTaskList.ts",
    "resource/apt.ts",
    "resource/exec.ts",
    "resource/file.ts",
    "resource/fileLine.ts",
    "resource/group.ts",
    "resource/index.ts",
    "resource/package.ts",
    "resource/service.ts",
    "resource/systemdService.ts",
    "resource/user.ts",
    "types/index.ts",
    "types/input.ts",
    "types/output.ts",
    "utilities.ts"
  ]
}
